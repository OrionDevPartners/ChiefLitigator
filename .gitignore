# ============================================
# CIPHERGY — GITIGNORE
# CRITICAL: Case files and secrets NEVER enter version control
# ============================================

# === SECRETS & CREDENTIALS ===
.env
.env.*
!.env.example
*.pem
*.key
*.p12
credentials.json
token.json
client_secret*.json
service-account*.json

# === CASE FILES (NEVER COMMIT CLIENT DATA) ===
case_structure/01-Pleadings/**/*.docx
case_structure/01-Pleadings/**/*.pdf
case_structure/02-Motions/**/*
case_structure/03-Discovery/**/*
case_structure/04-Depositions/**/*
case_structure/05-Correspondence/**/*
case_structure/06-Court-Orders/**/*
case_structure/07-Evidence/**/*
case_structure/08-Research-Memos/**/*.docx
case_structure/08-Research-Memos/**/*.pdf
case_structure/09-Trial-Preparation/**/*
case_structure/10-Settlement/**/*
case_structure/11-Administrative/**/*
!case_structure/**/.gitkeep

# === PYTHON ===
__pycache__/
*.py[cod]
*$py.class
*.so
.venv/
venv/
env/
*.egg-info/
dist/
build/
.eggs/

# === NODE ===
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.next/

# === IDE ===
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace

# === OS ===
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# === AWS ===
.aws/credentials
.aws/config

# === DOCKER ===
*.log

# === TERRAFORM (if used later) ===
.terraform/
*.tfstate
*.tfstate.*
*.tfvars
