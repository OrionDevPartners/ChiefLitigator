# =============================================================================
# CYPHERGY — PRODUCTION ENVIRONMENT (AWS ECS Fargate)
# THIS FILE IS A REFERENCE ONLY — actual values live in AWS Secrets Manager
# Never committed to git (.gitignore)
# =============================================================================

# === ENVIRONMENT ===
APP_ENV=production
DEBUG=false
LOG_LEVEL=INFO

# === LLM (Bedrock — via ECS task role, no keys needed) ===
LLM_PROVIDER=bedrock
LLM_MODEL=claude-opus-4-6
AWS_DEFAULT_REGION=us-east-1

# === WORKFLOW AUTOMATION (AWS-native, not n8n) ===
WORKFLOW_PROVIDER=aws_step_functions
# Step Functions + EventBridge — no N8N_ vars needed

# === DATABASE (RDS Aurora in VPC) ===
# Injected from: AWS Secrets Manager
DATABASE_URL=postgresql+asyncpg://cyphergy_admin:PASSWORD@cyphergy-beta.cgf2g0i0o0zu.us-east-1.rds.amazonaws.com:5432/cyphergy
DATABASE_ECHO=false

# === CACHE (ElastiCache in VPC) ===
REDIS_URL=redis://cyphergy-redis.xxx.use1.cache.amazonaws.com:6379/0

# === AUTH (Injected from Secrets Manager) ===
JWT_SECRET_KEY=<from-secrets-manager>
JWT_ALGORITHM=HS256
JWT_EXPIRY_SECONDS=1800
ADMIN_JWT_SECRET=<from-secrets-manager>
ADMIN_EMAIL=bo@symio.ai

# === SECURITY (Fully enforced) ===
BETA_GATE_ENABLED=true
IP_LOCK_ENABLED=true
RATE_LIMIT_ENABLED=true
CORS_ALLOWED_ORIGINS=https://cyphergy.ai,https://admin.cyphergy.ai

# === FEATURE FLAGS (Progressive — enable one at a time) ===
DUAL_BRAIN_ENABLED=false
WDC_EXTENDED_PANEL=false
CRAWLER_ENABLED=false
HOLDING_EXTRACTION_ENABLED=false
ARGUMENT_GRAPH_ENABLED=false

# === EXTERNAL SERVICES ===
COURTLISTENER_API_URL=https://www.courtlistener.com/api/rest/v4
COURTLISTENER_API_KEY=<from-secrets-manager>
EXTERNAL_RETRIEVAL_REQUIRED=true

# === BEDROCK CORE ===
BEDROCK_GUARDRAIL_ID=unvvioba92xr
BEDROCK_GUARDRAIL_VERSION=DRAFT
BEDROCK_AGENT_ID=CDW4VT55KB

# === MONITORING (Required) ===
SENTRY_DSN=<from-secrets-manager>
SENTRY_ENABLED=true
SENTRY_TRACES_SAMPLE_RATE=0.1

# === FILE STORAGE (S3) ===
FILE_STORAGE_PROVIDER=s3
S3_CASE_FILES_BUCKET=cyphergy-documents
S3_REGION=us-east-1
