# =============================================================================
# Cyphergy — Docker Build Context Exclusions
# Keep the build context small and exclude secrets/unnecessary files
# =============================================================================

# Git
.git
.gitignore

# Environment and secrets
.env
.env.*
!.env.example
*.pem
*.key
credentials.json

# Case files (client data never enters containers)
case_structure/

# Python artifacts
__pycache__
*.py[cod]
*.egg-info
dist/
build/
.eggs/
.venv/
venv/

# Testing
.pytest_cache/
htmlcov/
.coverage
.mypy_cache/

# IDE
.vscode/
.idea/
*.swp

# OS
.DS_Store
Thumbs.db

# Documentation and specs (not needed at runtime)
DOCS/
RUNBOOK/
CIPHERGY-REPO/
Ciphergy-extraction/
ciphergy-os-prompt/
*.docx
*.zip
*.pdf
*.md
!README.md

# Infrastructure (not needed in container image)
infrastructure/
scripts/
docker-compose.yml

# Claude
.claude/
