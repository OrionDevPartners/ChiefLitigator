# ==============================================================================
# CHIEFLITIGATOR — ENVIRONMENT CONFIGURATION
# ==============================================================================
# Copy this file to .env and populate with actual values.
# NEVER commit .env to version control.
# All secrets via env vars / AWS Secrets Manager / Parameter Store.
# ==============================================================================

# ==============================================================================
# APPLICATION
# ==============================================================================
APP_ENV=production
APP_VERSION=1.0.0
ENVIRONMENT=production
LOG_LEVEL=INFO
BETA_GATE_ENABLED=true

# ==============================================================================
# AWS INFRASTRUCTURE
# ==============================================================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_ECR_REGISTRY=
AWS_ECS_CLUSTER=chieflitigator
AWS_ECS_SERVICE=chieflitigator-api

# ==============================================================================
# AWS BEDROCK (LLM Provider)
# ==============================================================================
LLM_PROVIDER=bedrock
BEDROCK_TIER1_MODEL=anthropic.claude-opus-4-6-v1:0
BEDROCK_TIER2_MODEL=anthropic.claude-sonnet-4-6-20260301-v1:0
BEDROCK_TIER3_MODEL=anthropic.claude-haiku-3-6-20250401-v1:0
BEDROCK_DEFAULT_MODEL=anthropic.claude-sonnet-4-6-20260301-v1:0
BEDROCK_MAX_TOKENS=200000
BEDROCK_TEMPERATURE=0.0

# ==============================================================================
# AWS BEDROCK EMBEDDINGS (Titan V2 for pgvector)
# ==============================================================================
BEDROCK_EMBEDDING_MODEL=amazon.titan-embed-text-v2:0
BEDROCK_EMBEDDING_DIMENSIONS=1536

# ==============================================================================
# AWS BEDROCK GUARDRAILS
# ==============================================================================
BEDROCK_GUARDRAIL_ID=
BEDROCK_GUARDRAIL_VERSION=DRAFT

# ==============================================================================
# THE GALVANIZER (Adversarial Panel Engine)
# ==============================================================================
GALVANIZER_CONFIDENCE_GATE=0.90
GALVANIZER_MAX_ROUNDS=5
GALVANIZER_ESCALATION_DELTA=0.03
WDC_CERTIFICATION_THRESHOLD=8.5
EXTERNAL_RETRIEVAL_REQUIRED=true

# ==============================================================================
# DATABASE — Aurora PostgreSQL (pgvector)
# ==============================================================================
DATABASE_URL=
AURORA_DSN=

# ==============================================================================
# DATABASE — DynamoDB (user sessions, case state, Galvanizer logs)
# ==============================================================================
DYNAMO_SESSIONS_TABLE=ChiefLitigator_Sessions
DYNAMO_CASES_TABLE=ChiefLitigator_Cases
DYNAMO_GALVANIZER_TABLE=ChiefLitigator_GalvanizerLogs

# ==============================================================================
# REDIS (caching, rate limiting)
# ==============================================================================
REDIS_URL=

# ==============================================================================
# CLOUDFLARE
# ==============================================================================
CLOUDFLARE_API_KEY=
CLOUDFLARE_EMAIL=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_ACCOUNT_ID=

# ==============================================================================
# CORS
# ==============================================================================
CORS_ORIGINS=https://chieflitigator.com,https://www.chieflitigator.com,https://chieflitigator.ai,https://www.chieflitigator.ai

# ==============================================================================
# LEGAL DATA SOURCES — Siphon Pipeline
# ==============================================================================
COURTLISTENER_API_URL=https://www.courtlistener.com/api/rest/v4
COURTLISTENER_API_KEY=
COURTLISTENER_API_TOKEN=
LEGISCAN_API_URL=https://api.legiscan.com
LEGISCAN_API_KEY=
GOVINFO_API_URL=https://api.govinfo.gov
GOVINFO_API_KEY=DEMO_KEY
SCOTUS_API_URL=https://api.oyez.org

# ==============================================================================
# COURT PORTAL INTEGRATIONS — E-Filing
# ==============================================================================
PACER_API_URL=https://pcl.uscourts.gov/pcl-public-api/rest
PACER_USERNAME=
PACER_PASSWORD=
EFILE_TEXAS_KEY=
EFILE_IL_KEY=
NYSCEF_KEY=
TRUEFILING_KEY=

# ==============================================================================
# AUTHENTICATION & ADMIN
# ==============================================================================
ADMIN_JWT_SECRET=
ADMIN_PASSWORD_HASH=

# ==============================================================================
# OPTIONAL — Fallback LLM Providers
# ==============================================================================
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# COHERE_API_KEY=
