# ==============================================================================
# CYPHERGY LEGAL — ENVIRONMENT CONFIGURATION
# ==============================================================================
# Copy this file to .env and populate with actual values.
# NEVER commit .env to version control.
# CPAA (Code-Provider Agnostic Architecture): All providers configured via env vars.
# All secrets are CPAA-compliant: mount at runtime, never bake into images.

# ==============================================================================
# LLM PROVIDERS (CPAA — mount at runtime)
# ==============================================================================
# Supported providers: anthropic, openai, others (via environment routing)
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
LLM_MODEL=claude-opus-4-6

# Optional: Alternative LLM providers (if multi-provider support enabled)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4-turbo-preview

# ==============================================================================
# AWS INFRASTRUCTURE
# ==============================================================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_ECR_REGISTRY=
AWS_ECS_CLUSTER=cyphergy
AWS_ECS_SERVICE=cyphergy-api

# ==============================================================================
# CLOUDFLARE
# ==============================================================================
CLOUDFLARE_API_KEY=
CLOUDFLARE_EMAIL=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_ACCOUNT_ID=

# ==============================================================================
# LEGAL DATA SOURCES
# ==============================================================================
# CourtListener integration for case law retrieval
COURTLISTENER_API_URL=https://www.courtlistener.com/api/rest/v4
COURTLISTENER_API_KEY=

# Optional: US Code / CFR API (for statutory citations)
# CFR_API_URL=https://www.federalregister.gov/api/v1
# CFR_API_KEY=

# ==============================================================================
# DATABASE
# ==============================================================================
# PostgreSQL connection for document storage, citation cache, audit logs
DATABASE_URL=postgresql://cyphergy:password@localhost:5432/cyphergy

# ==============================================================================
# REDIS (Cache & Session Store)
# ==============================================================================
REDIS_URL=redis://localhost:6379/0

# ==============================================================================
# GITHUB
# ==============================================================================
GITHUB_TOKEN=

# ==============================================================================
# PROJECT MANAGEMENT (Linear)
# ==============================================================================
LINEAR_TOKEN=
LINEAR_TEAM_ID=

# ==============================================================================
# EXPO (React Native mobile app)
# ==============================================================================
EXPO_TOKEN=
EAS_PROJECT_ID=

# ==============================================================================
# VERCEL / V0 (Frontend)
# ==============================================================================
V0_API_KEY=
VERCEL_TOKEN=
VERCEL_PROJECT_ID=

# ==============================================================================
# AI/ML (HuggingFace)
# ==============================================================================
HF_TOKEN=
HF_MODEL_ENDPOINT=

# ==============================================================================
# DEVIN (AI Dev Agent)
# ==============================================================================
DEVIN_TOKEN=

# ==============================================================================
# MONITORING (Sentry)
# ==============================================================================
SENTRY_DSN=
SENTRY_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=cyphergy

# ==============================================================================
# APPLICATION CONFIGURATION
# ==============================================================================
# Environment: development, staging, production
APP_ENV=development

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Application secret key (change in production)
SECRET_KEY=change-me-in-production

# ==============================================================================
# WEIGHTED DEBATE CONSENSUS (WDC) CONFIGURATION
# ==============================================================================
# WDC v2.0 scoring thresholds for legal output validation
# Composite score threshold for CERTIFIED outputs (0-10 scale)
WDC_CERTIFICATION_THRESHOLD=8.5

# Minimum score for revision-needed outputs (5-8.4 range)
WDC_REVISION_THRESHOLD=5.0

# Enable WDC multi-agent consensus mode (Phase 1+)
WDC_MULTI_AGENT_ENABLED=false

# ==============================================================================
# VERIFICATION CHAIN
# ==============================================================================
# Require external source retrieval for citation verification
EXTERNAL_RETRIEVAL_REQUIRED=true

# Minimum cosine similarity for citation match acceptance
CITATION_SIMILARITY_THRESHOLD=0.85

# ==============================================================================
# JWT AUTHENTICATION
# ==============================================================================
# Secret key used to sign and verify JWT tokens (HS256).
# Generate a strong random key for production (e.g., openssl rand -hex 32).
JWT_SECRET_KEY=
# Token lifetime in seconds (default: 1800 = 30 minutes)
JWT_EXPIRY_SECONDS=1800
# Signing algorithm (default: HS256)
JWT_ALGORITHM=HS256

# ==============================================================================
# SECURITY & ENCRYPTION
# ==============================================================================
# AES-256-GCM encryption key for sensitive data (Phase 1+)
# ENCRYPTION_KEY=

# PII scrubbing mode: aggressive, moderate, minimal
# PII_SCRUBBING_MODE=moderate

# ==============================================================================
# COMPLIANCE & AUDIT
# ==============================================================================
# HIPAA_ENABLED=false
# GDPR_ENABLED=true
# CCPA_ENABLED=true
# CITATION_VERIFICATION_HARD_CONSTRAINT=true

# ==============================================================================
# FEATURE FLAGS
# ==============================================================================
# BATCH_DOCUMENT_INTAKE_ENABLED=false
# OFFLINE_COURTROOM_ENABLED=false

# ==============================================================================
# DEBUG & DEVELOPMENT
# ==============================================================================
# DEBUG_API_CALLS=false
# DEBUG_LLM_CALLS=false
# TELEMETRY_ENABLED=true

# === BEDROCK CORE ===
BEDROCK_GUARDRAIL_ID=
BEDROCK_GUARDRAIL_VERSION=DRAFT
BEDROCK_AGENT_ID=
BEDROCK_AGENT_ALIAS=

# === APIFY (Web Scraping — feeds jurisdiction containers) ===
APIFY_TOKEN=
APIFY_BASE_URL=https://api.apify.com/v2

# === N8N (Workflow Automation — self-hosted, replaces Zapier) ===
N8N_TOKEN=
N8N_BASE_URL=http://localhost:5678

# === BRAVE SEARCH ===
BRAVE_TOKEN=
